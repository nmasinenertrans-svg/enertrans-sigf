generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  DEV
  GERENTE
  COORDINADOR
  AUDITOR
  MECANICO
}

enum FleetOperationalStatus {
  OPERATIONAL
  MAINTENANCE
  OUT_OF_SERVICE
}

enum FleetUnitType {
  CHASSIS
  CHASSIS_WITH_HYDROCRANE
  TRACTOR
  TRACTOR_WITH_HYDROCRANE
  SEMI_TRAILER
  AUTOMOBILE
  VAN
  PICKUP
}

enum AuditResult {
  APPROVED
  REJECTED
}

enum WorkOrderStatus {
  OPEN
  IN_PROGRESS
  CLOSED
}

enum VisualStatus {
  OVERDUE
  OK
  DUE_SOON
}

enum FleetMovementType {
  ENTRY
  RETURN
}

enum FleetLogisticsStatus {
  AVAILABLE
  PENDING_DELIVERY
  DELIVERED
  PENDING_RETURN
  RETURNED
}

enum DeliveryOperationType {
  DELIVERY
  RETURN
}

enum TaskStatus {
  UNASSIGNED
  ASSIGNED
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum CurrencyCode {
  ARS
  USD
}

enum TaskEventType {
  CREATED
  UPDATED
  ASSIGNED
  UNASSIGNED
  MOVED_TO_BANK
  REMOVED_FROM_BANK
  TAKEN_FROM_BANK
  STATUS_CHANGED
}

enum CrmDealStage {
  LEAD
  CONTACTED
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum CrmActivityType {
  CALL
  WHATSAPP
  EMAIL
  MEETING
  TASK
}

enum CrmActivityStatus {
  PENDING
  DONE
}

model User {
  id                  String   @id @default(uuid())
  username            String   @unique
  fullName            String
  role                UserRole
  passwordHash        String
  avatarUrl           String   @default("")
  permissions         Json?
  permissionOverrides Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  audits              AuditRecord[]
  tasksCreated        Task[]      @relation("TaskCreatedBy")
  tasksAssigned       Task[]      @relation("TaskAssignedTo")
  tasksAssignedBy     Task[]      @relation("TaskAssignedBy")
  taskEvents          TaskEvent[] @relation("TaskEventActor")
  deliveryOperationsRequested DeliveryOperation[] @relation("DeliveryRequestedBy")
  crmDealsCreated     CrmDeal[]      @relation("CrmDealCreatedBy")
  crmDealsAssigned    CrmDeal[]      @relation("CrmDealAssignedTo")
  crmActivitiesCreated CrmActivity[] @relation("CrmActivityCreatedBy")
}

model FleetUnit {
  id                       String   @id @default(uuid())
  qrId                     String   @unique
  internalCode             String   @unique
  brand                    String
  model                    String
  year                     Int      @default(0)
  clientId                 String?
  clientName               String   @default("")
  location                 String   @default("")
  ownerCompany             String
  operationalStatus        FleetOperationalStatus
  logisticsStatus          FleetLogisticsStatus @default(AVAILABLE)
  logisticsStatusNote      String   @default("")
  logisticsUpdatedAt       DateTime?
  unitType                 FleetUnitType
  configurationNotes       String
  chassisNumber            String
  engineNumber             String
  tareWeightKg             Int
  maxLoadKg                Int
  hasHydroCrane            Boolean
  hydroCraneBrand          String
  hydroCraneModel          String
  hydroCraneSerialNumber   String
  hasSemiTrailer           Boolean
  semiTrailerUnitId        String?
  semiTrailerLicensePlate  String
  semiTrailerBrand         String
  semiTrailerModel         String
  semiTrailerYear          Int
  semiTrailerChassisNumber String
  tractorHistoryIds        Json
  currentKilometers        Int      @default(0)
  currentEngineHours       Int      @default(0)
  currentHydroHours        Int      @default(0)
  lubricants               Json
  filters                  Json
  documents                Json
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  semiTrailer              FleetUnit?  @relation("SemiTrailer", fields: [semiTrailerUnitId], references: [id])
  tractors                 FleetUnit[] @relation("SemiTrailer")
  client                   ClientAccount? @relation(fields: [clientId], references: [id])

  maintenancePlans         MaintenancePlan[]
  audits                   AuditRecord[]
  workOrders               WorkOrder[]
  repairs                  RepairRecord[]
  externalRequests         ExternalRequest[]
  movementLinks            FleetMovementUnit[]
  deliveryOperations       DeliveryOperation[]

  @@index([clientId])
  @@index([logisticsStatus])
}

model MaintenancePlan {
  id                      String   @id @default(uuid())
  unitId                  String
  currentKilometers       Int
  currentHours            Int
  nextServiceByKilometers Int
  nextServiceByHours      Int
  oils                    Json
  filters                 Json
  notes                   String
  status                  VisualStatus
  serviceSchedule         Json
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  unit FleetUnit @relation(fields: [unitId], references: [id])
}

model AuditRecord {
  id             String   @id @default(uuid())
  code           String   @unique
  auditKind      String   @default("AUDIT")
  unitId         String
  auditorUserId  String
  auditorName    String
  workOrderId    String?
  performedAt    DateTime
  result         AuditResult
  observations   String
  photoUrls      Json
  checklist      Json
  unitKilometers Int      @default(0)
  engineHours    Int      @default(0)
  hydroHours     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  unit    FleetUnit @relation(fields: [unitId], references: [id])
  auditor User      @relation(fields: [auditorUserId], references: [id])
}

model WorkOrder {
  id                     String   @id @default(uuid())
  code                   String   @unique
  pendingReaudit         Boolean  @default(false)
  unitId                 String
  status                 WorkOrderStatus
  taskList               Json
  spareParts             Json
  laborDetail            String
  linkedInventorySkuList Json
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  unit FleetUnit @relation(fields: [unitId], references: [id])
}

model RepairRecord {
  id               String   @id @default(uuid())
  unitId           String
  workOrderId      String?
  externalRequestId String? 
  sourceType       String   @default("WORK_ORDER")
  supplierId       String?
  performedAt      DateTime @default(now())
  unitKilometers   Int      @default(0)
  currency         CurrencyCode @default(ARS)
  supplierName     String
  linkedExternalRequestIds Json   @default("[]")
  laborCost         Float   @default(0)
  partsCost         Float   @default(0)
  realCost         Float
  invoicedToClient Float
  margin           Float
  invoiceFileName  String   @default("")
  invoiceFileBase64 String  @default("")
  invoiceFileUrl   String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  unit FleetUnit @relation(fields: [unitId], references: [id])
  supplier Supplier? @relation(fields: [supplierId], references: [id])
  externalRequestsLinked ExternalRequest[] @relation("ExternalRequestsLinkedToRepair")
}

model InventoryItem {
  id                 String   @id @default(uuid())
  sku                String   @unique
  productName        String
  stock              Int
  movementHistory    Json
  linkedWorkOrderIds Json
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ExternalRequest {
  id          String   @id @default(uuid())
  code        String   @unique
  unitId      String
  companyName String
  description String
  tasks       Json
  currency    String   @default("ARS")
  partsItems  Json     @default("[]")
  partsTotal  Float    @default(0)
  eligibilityStatus String @default("PENDING_ATTACHMENT")
  linkedRepairId String?
  providerFileName String   @default("")
  providerFileUrl  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  unit FleetUnit @relation(fields: [unitId], references: [id])
  linkedRepair RepairRecord? @relation("ExternalRequestsLinkedToRepair", fields: [linkedRepairId], references: [id])

  @@index([linkedRepairId])
}

model FleetMovement {
  id                   String            @id @default(uuid())
  movementType         FleetMovementType
  remitoNumber         String            @default("")
  remitoDate           DateTime?
  clientName           String            @default("")
  workLocation         String            @default("")
  equipmentDescription String            @default("")
  observations         String            @default("")
  deliveryContactName  String            @default("")
  deliveryContactDni   String            @default("")
  deliveryContactSector String           @default("")
  deliveryContactRole  String            @default("")
  receiverContactName  String            @default("")
  receiverContactDni   String            @default("")
  receiverContactSector String           @default("")
  receiverContactRole  String            @default("")
  pdfFileName          String            @default("")
  pdfFileUrl           String            @default("")
  parsedPayload        Json?
  createdAt            DateTime          @default(now())
  updatedAt            DateTime          @updatedAt

  units FleetMovementUnit[]
}

model FleetMovementUnit {
  movementId String
  unitId     String

  movement FleetMovement @relation(fields: [movementId], references: [id])
  unit     FleetUnit     @relation(fields: [unitId], references: [id])

  @@id([movementId, unitId])
}

model Task {
  id               String       @id @default(uuid())
  title            String       @default("")
  description      String
  status           TaskStatus   @default(UNASSIGNED)
  priority         TaskPriority @default(MEDIUM)
  assignedToUserId String?
  assignedByUserId String?
  createdByUserId  String
  isInTaskBank     Boolean      @default(false)
  closedAt         DateTime?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  assignedTo User?      @relation("TaskAssignedTo", fields: [assignedToUserId], references: [id])
  assignedBy User?      @relation("TaskAssignedBy", fields: [assignedByUserId], references: [id])
  createdBy  User       @relation("TaskCreatedBy", fields: [createdByUserId], references: [id])
  events     TaskEvent[]

  @@index([status])
  @@index([priority])
  @@index([assignedToUserId])
  @@index([isInTaskBank])
}

model TaskEvent {
  id                   String        @id @default(uuid())
  taskId               String
  type                 TaskEventType
  actorUserId          String
  notes                String        @default("")
  fromStatus           TaskStatus?
  toStatus             TaskStatus?
  fromAssignedToUserId String?
  toAssignedToUserId   String?
  createdAt            DateTime      @default(now())

  task   Task @relation(fields: [taskId], references: [id])
  actor  User @relation("TaskEventActor", fields: [actorUserId], references: [id])

  @@index([taskId, createdAt])
  @@index([actorUserId])
}

model Sequence {
  key   String @id
  value Int
}

model AppSettings {
  id                 String   @id @default("app")
  maintenanceEnabled Boolean  @default(false)
  maintenanceMessage String   @default("")
  featureFlags       Json     @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model ClientAccount {
  id            String   @id @default(uuid())
  name          String   @unique
  legalName     String   @default("")
  taxId         String   @default("")
  contactName   String   @default("")
  contactPhone  String   @default("")
  contactEmail  String   @default("")
  notes         String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  units         FleetUnit[]
  deliveries    DeliveryOperation[]
  crmDeals      CrmDeal[]
}

model Supplier {
  id            String   @id @default(uuid())
  name          String   @unique
  serviceType   String   @default("")
  paymentMethod String   @default("")
  paymentTerms  String   @default("")
  address       String   @default("")
  mapsUrl       String   @default("")
  contactName   String   @default("")
  contactPhone  String   @default("")
  contactEmail  String   @default("")
  notes         String   @default("")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repairs       RepairRecord[]
}

model DeliveryOperation {
  id                   String                @id @default(uuid())
  unitId               String
  clientId             String?
  operationType        DeliveryOperationType
  targetLogisticsStatus FleetLogisticsStatus
  summary              String                @default("")
  reason               String                @default("")
  remitoFileName       String                @default("")
  remitoFileUrl        String                @default("")
  remitoAttachedAt     DateTime?
  remitoAttachedByUserName String            @default("")
  requestedByUserId    String?
  requestedByUserName  String                @default("")
  effectiveAt          DateTime              @default(now())
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt

  unit                 FleetUnit             @relation(fields: [unitId], references: [id])
  client               ClientAccount?        @relation(fields: [clientId], references: [id])
  requestedByUser      User?                 @relation("DeliveryRequestedBy", fields: [requestedByUserId], references: [id])

  @@index([unitId, createdAt])
  @@index([clientId, createdAt])
  @@index([operationType, createdAt])
}

model CrmDeal {
  id                 String          @id @default(uuid())
  title              String
  companyName        String
  contactName        String          @default("")
  contactEmail       String          @default("")
  contactPhone       String          @default("")
  source             String          @default("")
  serviceLine        String          @default("")
  amount             Float           @default(0)
  currency           CurrencyCode    @default(ARS)
  probability        Int             @default(10)
  stage              CrmDealStage    @default(LEAD)
  expectedCloseDate  DateTime?
  lastContactAt      DateTime?
  lostReason         String          @default("")
  notes              String          @default("")
  assignedToUserId   String?
  convertedClientId  String?
  createdByUserId    String
  wonAt              DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  assignedToUser     User?           @relation("CrmDealAssignedTo", fields: [assignedToUserId], references: [id])
  createdByUser      User            @relation("CrmDealCreatedBy", fields: [createdByUserId], references: [id])
  convertedClient    ClientAccount?  @relation(fields: [convertedClientId], references: [id])
  activities         CrmActivity[]

  @@index([stage, createdAt])
  @@index([assignedToUserId, stage])
  @@index([convertedClientId])
  @@index([companyName])
}

model CrmActivity {
  id              String            @id @default(uuid())
  dealId          String
  type            CrmActivityType
  status          CrmActivityStatus @default(PENDING)
  summary         String
  dueAt           DateTime?
  completedAt     DateTime?
  createdByUserId String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  deal            CrmDeal           @relation(fields: [dealId], references: [id])
  createdByUser   User              @relation("CrmActivityCreatedBy", fields: [createdByUserId], references: [id])

  @@index([dealId, status, dueAt])
  @@index([createdByUserId, createdAt])
}
