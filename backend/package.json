{
    "name": "backend",
    "version": "1.0.0",
    "description": "Enertrans SIGF backend",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "dev": "tsx watch src/index.ts",
        "start": "node dist/index.js || node dist/src/index.js",
        "build": "prisma generate && tsc",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate:deploy": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "storage:audits:orphan:report": "tsx scripts/reconcileAuditStorage.ts",
        "storage:audits:orphan:clean": "tsx scripts/reconcileAuditStorage.ts --delete"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@prisma/client": "^6.16.1",
        "@sentry/node": "^10.40.0",
        "@supabase/supabase-js": "^2.95.3",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.2.4",
        "express": "^5.2.1",
        "jsonwebtoken": "^9.0.3",
        "pdf-parse": "^1.1.1",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/node": "^25.2.3",
        "@types/pdf-parse": "^1.1.5",
        "prisma": "^6.16.1",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3"
    }
